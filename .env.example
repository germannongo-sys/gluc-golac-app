# Base de données PostgreSQL (Supabase ou autre)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gluc_db?schema=public"

# JWT — générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_min_32_chars_random_secret"
JWT_REFRESH_SECRET="CHANGE_ME_another_random_refresh_secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# URL du frontend (pour CORS en production)
FRONTEND_URL="https://your-app.netlify.app"

# Optionnel : Supabase Storage pour les fichiers/logos
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
